# Example cluster profile — copy this to create your own:
#   cp clusters/example.env clusters/my-cluster.env
#
# Then edit the values. All nodes in a cluster must share the same token.
# Generate a token with: openssl rand -hex 32

CLUSTER_NAME="my-cluster"
K3S_TOKEN="REPLACE_ME_WITH_openssl_rand_-hex_32"
K3S_MDNS_SERVICE="_k3s-my-cluster._tcp"
K3S_EXTRA_SERVER_ARGS="--disable traefik"
K3S_EXTRA_AGENT_ARGS=""
K3S_VERSION=""
LONGHORN_VERSION=""
