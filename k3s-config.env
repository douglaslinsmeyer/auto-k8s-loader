# ── K3s Bootstrap Configuration ──────────────────────────────────────
# Edit these values before flashing the USB drive.

# K3s version (empty = latest stable)
K3S_VERSION=""

# Cluster token — all nodes in the same cluster MUST share this value.
# Generate one with: openssl rand -hex 32
K3S_TOKEN="6b0356af7e673016c7e2929ebac564a1f00d5b0ea17f8fb549c60627946eeab6"

# The k3s API server port (default 6443)
K3S_API_PORT="6443"

# mDNS service name used to discover existing cluster servers.
# The first-boot script will look for _k3s-server._tcp on the local network.
# If found → join as agent (or additional server). If not found → init new cluster.
K3S_MDNS_SERVICE="_k3s-server._tcp"

# Force a specific role regardless of auto-detection.
# Values: "" (auto-detect), "server", "agent"
K3S_FORCE_ROLE=""

# Extra flags passed to k3s server or agent install.
K3S_EXTRA_SERVER_ARGS="--disable traefik"
K3S_EXTRA_AGENT_ARGS=""

# Network CIDR overrides (leave empty for k3s defaults)
K3S_CLUSTER_CIDR=""
K3S_SERVICE_CIDR=""

# How many seconds to wait for mDNS discovery before deciding to init
K3S_DISCOVERY_TIMEOUT=30
